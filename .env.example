# Google Ads Performance Max — cross-domain tracking linker tag.
# Same ID must be used on app.getpurview.com for attribution to work.
NEXT_PUBLIC_GOOGLE_ADS_ID=AW-18091538205

# Meta Pixel ID — used for ads attribution, retargeting, and conversion tracking.
# Same ID must be used on app.getpurview.com for cross-domain attribution to work.
# Pixel never loads (consent banner still functions, no-op tracking) if this is unset.
NEXT_PUBLIC_META_PIXEL_ID=1218512860395251
